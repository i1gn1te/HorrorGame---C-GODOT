mtllib level0_floor_reference.mtl
o level0_floor_reference
usemtl level0_real_carpet
# 18 x 26 meter reference floor for Level 0.
# Blender: X is width, Y is depth after import if you rotate/convert axes.
# Godot: this OBJ uses X and Z as floor axes, Y as height.
v -9.0 0.0 -13.0
v 9.0 0.0 -13.0
v 9.0 0.0 13.0
v -9.0 0.0 13.0
vt 0.0 0.0
vt 5.5 0.0
vt 5.5 7.5
vt 0.0 7.5
vn 0.0 1.0 0.0
f 1/1/1 2/2/1 3/3/1 4/4/1
